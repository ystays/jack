# Qobuz API credentials. Keep these server-side only.
QOBUZ_APP_ID=
QOBUZ_USER_AUTH_TOKEN=

# Streamrip command/config.
STREAMRIP_BIN=rip
STREAMRIP_CONFIG=/srv/qobuz-import/streamrip.toml

# Download staging and final Navidrome library paths.
MUSIC_INCOMING_DIR=/srv/music-incoming
MUSIC_DIR=/srv/music

# Default Qobuz/streamrip quality: 1=320kbps, 2=CD, 3=24bit <=96kHz, 4=24bit <=192kHz.
DEFAULT_QUALITY=3

