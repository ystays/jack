# Qobuz API credentials. Keep these server-side only.
QOBUZ_APP_ID=
QOBUZ_USER_AUTH_TOKEN=

# Streamrip command/config.
STREAMRIP_BIN=rip
STREAMRIP_CONFIG=./streamrip.toml

# Download/final Navidrome library path.
MUSIC_DIR=/media/ys/SAMSUNG/MUSIC

# Default Qobuz/streamrip quality: 1=320kbps, 2=CD, 3=24bit <=96kHz, 4=24bit <=192kHz.
DEFAULT_QUALITY=3
